{
  "name": "@pca/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.11"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "pca-source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./forbidden-scan": {
      "types": "./dist/forbidden-scan.d.ts",
      "pca-source": "./src/forbidden-scan.ts",
      "default": "./dist/forbidden-scan.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "tsx src/generate.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pca/taxonomy": "workspace:*",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.23.0",
    "vitest": "^3.0.0"
  }
}
