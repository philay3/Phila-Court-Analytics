{
  "name": "@pca/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.9"
  },
  "scripts": {
    "migrate:latest": "tsx --env-file-if-exists=../.env src/migrate.ts latest",
    "migrate:up": "tsx --env-file-if-exists=../.env src/migrate.ts up",
    "migrate:down": "tsx --env-file-if-exists=../.env src/migrate.ts down",
    "migrate:status": "tsx --env-file-if-exists=../.env src/migrate.ts status",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "kysely": "^0.29.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0"
  }
}
