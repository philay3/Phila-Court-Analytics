{
  "name": "@pca/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.11"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "pca-source": "./src/index.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "migrate:latest": "tsx --conditions pca-source --env-file-if-exists=../.env src/migrate.ts latest",
    "migrate:up": "tsx --conditions pca-source --env-file-if-exists=../.env src/migrate.ts up",
    "migrate:down": "tsx --conditions pca-source --env-file-if-exists=../.env src/migrate.ts down",
    "migrate:status": "tsx --conditions pca-source --env-file-if-exists=../.env src/migrate.ts status",
    "seed": "pnpm --filter @pca/taxonomy run generate && tsx --conditions pca-source --env-file-if-exists=../.env seeds/run.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pca/taxonomy": "workspace:*",
    "kysely": "^0.29.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0",
    "vitest": "^3.0.0"
  }
}
