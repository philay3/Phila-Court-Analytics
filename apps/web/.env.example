# Base URL of the public API, used server-side only (no NEXT_PUBLIC_ prefix, so
# it never enters a client bundle). The Next.js rewrite in next.config.ts
# proxies browser /api/v1/public/* requests here, keeping them same-origin.
#
# OPTIONAL in local dev: both the rewrite and the server-side client resolve the
# base through app/lib/api-base-url.ts, which defaults to http://localhost:3001
# when this is unset — so you only need a .env here to point the web app at an
# API on a different host/port. Copy this file to .env and edit to override.
#
# http://localhost:3001 is a LOCAL-DEV DEFAULT ONLY (the API runs on 3001, web
# on 3000). Production env wiring that eliminates reliance on this default is
# Sprint 9 launch-readiness scope.
API_BASE_URL=http://localhost:3001
