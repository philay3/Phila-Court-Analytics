# Base URL of the public API, used server-side only (no NEXT_PUBLIC_ prefix, so
# it never enters a client bundle). The Next.js rewrite in next.config.ts
# proxies browser /api/v1/public/* requests here, keeping them same-origin.
#
# OPTIONAL under `next dev` and in unit tests: both the rewrite and the
# server-side client resolve the base through app/lib/api-base-url.ts, which
# defaults to http://localhost:3001 when this is unset.
#
# REQUIRED in production AND for any local command that runs Next with
# NODE_ENV=production — which Next applies to every CLI command except
# `next dev`. Concretely: `pnpm typecheck` (via `next typegen`),
# `pnpm --filter @pca/web run build`, and `pnpm test:e2e` all fail loudly
# (task 31.3 guard) unless API_BASE_URL is set here or exported in the shell.
# Copy this file to .env to satisfy them locally. In production it must point
# at the API service's internal hostname and be present at BUILD and runtime.
API_BASE_URL=http://localhost:3001
