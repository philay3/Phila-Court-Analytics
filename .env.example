# Local development environment variables.
# Copy to .env (`cp .env.example .env`) and adjust if needed.
# Placeholder local-dev values only — never put real secrets in this file.
# See docs/local-setup.md for setup instructions.

# --- Local PostgreSQL (Docker Compose) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=pca
POSTGRES_USER=pca
POSTGRES_PASSWORD=pca_local_dev_password

# Composed connection string for tools that take a single URL.
# Keep in sync with the discrete POSTGRES_* variables above.
DATABASE_URL=postgres://pca:pca_local_dev_password@localhost:5433/pca

# --- Production database (operational dump/restore runs only) ---
# Retention ruled at Sprint 7 close: kept under this isolated name — never
# `DATABASE_URL` — and the real value lives only in the local gitignored .env.
PROD_DATABASE_URL=replace-with-render-external-connection-string-never-commit

# --- Pipeline: pseudonymous defendant hashing ---
# Salt for the defendant hash. REQUIRED — there is no default; the pipeline
# raises if it is missing or empty. Must stay STABLE across all runs, or the
# same defendant hashes differently and records will not link. Set a real,
# random value in your local .env and NEVER commit it.
DEFENDANT_HASH_SALT=replace-with-a-stable-random-local-dev-salt
