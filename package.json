{
  "name": "philadelphia-court-outcomes",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.11"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "build:packages": "pnpm --filter @pca/taxonomy --filter @pca/shared --filter @pca/db run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate": "pnpm -r run generate",
    "typecheck": "pnpm run build:packages && tsc -p tsconfig.json && pnpm -r run typecheck",
    "test": "pnpm run generate && pnpm -r run test",
    "test:e2e": "pnpm run build:packages && pnpm --filter @pca/api run build && pnpm --filter @pca/web run build && pnpm --filter @pca/e2e run test:e2e",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v",
    "db:migrate:latest": "pnpm --filter @pca/db run migrate:latest",
    "db:migrate:up": "pnpm --filter @pca/db run migrate:up",
    "db:migrate:down": "pnpm --filter @pca/db run migrate:down",
    "db:migrate:status": "pnpm --filter @pca/db run migrate:status",
    "db:seed": "pnpm --filter @pca/db run seed",
    "taxonomy:validate": "pnpm --filter @pca/taxonomy run validate",
    "taxonomy:generate": "pnpm --filter @pca/taxonomy run generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
